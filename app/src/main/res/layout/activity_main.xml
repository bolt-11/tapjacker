<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_variant">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/app_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Permission card -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_permission"
                        android:textColor="@color/brand_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPermissionStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_status_pill"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/permission_status_denied"
                        android:textColor="@color/danger" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantPermission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_grant_permission"
                        android:textColor="@color/on_brand_primary"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Overlay configuration card -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_config"
                        android:textColor="@color/brand_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilButtonText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:hintEnabled="false"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etButtonText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_button_text"
                            android:maxLines="2" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvWidthLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_width"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderWidth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="4"
                        android:value="220"
                        android:valueFrom="80"
                        android:valueTo="360"
                        app:thumbColor="@color/brand_primary"
                        app:trackColorActive="@color/brand_primary" />

                    <TextView
                        android:id="@+id/tvHeightLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_height"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="2"
                        android:value="56"
                        android:valueFrom="36"
                        android:valueTo="160"
                        app:thumbColor="@color/brand_primary"
                        app:trackColorActive="@color/brand_primary" />

                    <TextView
                        android:id="@+id/tvOpacityLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_opacity"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOpacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="5"
                        android:value="100"
                        android:valueFrom="30"
                        android:valueTo="100"
                        app:thumbColor="@color/brand_primary"
                        app:trackColorActive="@color/brand_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/label_color"
                        android:textColor="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="5">

                        <View
                            android:id="@+id/swatchRed"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_color_swatch"
                            android:backgroundTint="@color/decoy_red"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:id="@+id/swatchOrange"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_color_swatch"
                            android:backgroundTint="@color/decoy_orange"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:id="@+id/swatchGreen"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_color_swatch"
                            android:backgroundTint="@color/decoy_green"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:id="@+id/swatchBlue"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_color_swatch"
                            android:backgroundTint="@color/decoy_blue"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:id="@+id/swatchPurple"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_color_swatch"
                            android:backgroundTint="@color/decoy_purple"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchLock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/switch_lock_position" />

                    <TextView
                        android:id="@+id/tvDragHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/hint_drag"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShowOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/btn_show_overlay"
                        android:textColor="@color/on_brand_primary"
                        app:backgroundTint="@color/decoy_green"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
